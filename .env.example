# SQL Server (source) - SQLAlchemy URL with pymssql
# Example: mssql+pymssql://user:password@host:1433/database
# If password has @ : or #, percent-encode it (e.g. @ -> %40). Use one line, no quotes needed.
SQLSERVER_CONN_STR=

# PostgreSQL (destination) - where activity log rows are inserted
# Example: host=localhost port=5432 dbname=sql_log user=postgres password=secret
POSTGRES_CONN_STR=

# Polling interval in seconds. Lower values reduce missed short-lived lock/block events.
POLL_INTERVAL_SECONDS=15

# Optional collector toggles (1=true, 0=false)
CAPTURE_BLOCKING=1
CAPTURE_QUERY_STATS=1
CAPTURE_HEALTH_COUNTERS=1
CAPTURE_XEVENTS=1

# Number of top historical queries (by max elapsed time) captured each poll.
QUERY_STATS_TOP_N=50

# Extended Events session options.
# Requires VIEW SERVER STATE to read and ALTER ANY EVENT SESSION to auto-create/start.
XEVENT_SESSION_NAME=sql_monitor_diag
XEVENT_AUTO_CREATE_SESSION=1

# Web dashboard options
WEB_HOST=0.0.0.0
WEB_PORT=8000
DASHBOARD_STALE_MINUTES=5

# Basic auth for dashboard/API. If DASHBOARD_AUTH_ENABLED=1, set both username/password.
# If DASHBOARD_AUTH_ENABLED is empty, auth auto-enables when both username/password are set.
DASHBOARD_AUTH_ENABLED=
DASHBOARD_AUTH_USERNAME=
DASHBOARD_AUTH_PASSWORD=
