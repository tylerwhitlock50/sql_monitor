# SQL Server (source) - SQLAlchemy URL with pymssql
# Example: mssql+pymssql://user:password@host:1433/database
# If password has @ : or #, percent-encode it (e.g. @ -> %40). Use one line, no quotes needed.
SQLSERVER_CONN_STR=

# PostgreSQL (destination) - where activity log rows are inserted
# Example: host=localhost port=5432 dbname=sql_log user=postgres password=secret
POSTGRES_CONN_STR=

# How often to poll SQL Server (seconds). Optional; default is 60.
POLL_INTERVAL_SECONDS=60
