# SQL Server source connection (required)
# If SQL Server is running on your host machine, use host.docker.internal for the host.
# Example: mssql+pymssql://sa:YourStrong!Passw0rd@host.docker.internal:1433/master
SQLSERVER_CONN_STR=

# Postgres service credentials (for compose-managed Postgres)
POSTGRES_DB=sql_monitor
POSTGRES_USER=sql_monitor
POSTGRES_PASSWORD=sql_monitor

# Collector tuning
POLL_INTERVAL_SECONDS=15
CAPTURE_BLOCKING=1
CAPTURE_QUERY_STATS=1
CAPTURE_HEALTH_COUNTERS=1
CAPTURE_XEVENTS=1
QUERY_STATS_TOP_N=50
XEVENT_SESSION_NAME=sql_monitor_diag
XEVENT_AUTO_CREATE_SESSION=1

# Dashboard/web
WEB_BIND_PORT=8000
DASHBOARD_STALE_MINUTES=5

# Dashboard basic auth (recommended for non-local usage)
# Leave DASHBOARD_AUTH_ENABLED blank to auto-enable when username/password are set.
DASHBOARD_AUTH_ENABLED=
DASHBOARD_AUTH_USERNAME=
DASHBOARD_AUTH_PASSWORD=
